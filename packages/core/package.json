    "drizzle-orm": "^0.45.2",
    "glob": "^11.0.3",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "openai": "^4.0.0",
    "opossum": "^9.0.0",
    "ulid": "^2.3.0",
    "yaml": "^2.8.4",
    "zod": "^3.23.0"
