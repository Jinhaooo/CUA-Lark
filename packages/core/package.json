      "require": "./dist/preflight/index.js"
    },
    "./src/trace/SqliteTraceStore.js": {
      "import": "./src/trace/SqliteTraceStore.ts"
    },
    "./src/trace/EventBus.js": {
      "import": "./src/trace/EventBus.ts"
    },
    "./src/trace/TracePersister.js": {
      "import": "./src/trace/TracePersister.ts"
    },
    "./src/skill/SkillRegistry.js": {
      "import": "./src/skill/SkillRegistry.ts"
    },
    "./src/model/streaming.js": {
      "import": "./src/model/streaming.ts"
