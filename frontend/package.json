{
  "name": "cua-lark-frontend",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/main/main.js",
  "packageManager": "pnpm@9.10.0",
  "description": "CUA-Lark Electron frontend (forked from UI-TARS-desktop renderer + decoupled vendor deps)",
  "scripts": {
    "format": "prettier --write .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --pretty --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --pretty --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "dev": "electron-vite dev",
    "debug": "electron-vite dev --sourcemap --remote-debugging-port=9222",
    "build:dist": "cross-env NODE_ENV=production electron-vite build",
    "build": "npm run typecheck && cross-env NODE_ENV=production electron-vite build",
    "start": "electron-vite preview",
    "test": "vitest"
  },
  "dependencies": {
    "@computer-use/node-mac-permissions": "2.2.2",
    "axios": "^1.7.9",
    "jose": "^6.0.11",
    "openai": "^5.5.1",
    "sharp": "0.33.3",
    "source-map-support": "^0.5.21",
    "type-fest": "^4.30.0",
    "zod": "^3.24.2"
  },
  "pnpm": {
    "overrides": {
      "builder-util-runtime": "9.5.1"
    }
  },
  "devDependencies": {
    "@computer-use/mac-screen-capture-permissions": "^1.0.2",
    "@computer-use/nut-js": "^4.2.0",
    "@electron-forge/cli": "^7.7.0",
    "@electron-forge/maker-dmg": "^7.7.0",
    "@electron-forge/maker-pkg": "^7.7.0",
    "@electron-forge/maker-squirrel": "^7.7.0",
    "@electron-forge/maker-zip": "^7.7.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.7.0",
    "@electron-forge/plugin-base": "^7.7.0",
    "@electron-forge/plugin-fuses": "^7.7.0",
    "@electron-forge/plugin-vite": "^7.7.0",
    "@electron-forge/publisher-github": "^7.7.0",
    "@electron-forge/shared-types": "^7.7.0",
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@electron/asar": "^3.2.18",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/vite": "4.1.3",
    "@trivago/prettier-plugin-sort-imports": "^5.2.1",
    "@types/node": "^20.14.8",
    "@types/source-map-support": "^0.5.10",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "@ui-tars/action-parser": "^1.2.3",
    "@ui-tars/electron-ipc": "^1.2.3",
    "@ui-tars/operator-browser": "^1.2.3",
    "@ui-tars/operator-nut-js": "^1.2.3",
    "@ui-tars/sdk": "^1.2.3",
    "@ui-tars/shared": "^1.2.3",
    "@ui-tars/utio": "^1.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-istanbul": "^3.0.3",
    "bufferutil": "^4.1.0",
    "builder-util-runtime": "9.5.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "electron": "34.1.1",
    "electron-debug": "^3.2.0",
    "electron-devtools-installer": "^3.2.0",
    "electron-log": "5.2.4",
    "electron-packager-languages": "0.5.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.6.2",
    "electron-vite": "^3.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.25.0",
    "eslint-plugin-react": "^7.34.3",
    "js-yaml": "^4.1.0",
    "ms": "^2.1.3",
    "node-machine-id": "^1.1.12",
    "prettier": "^3.3.2",
    "rimraf": "^6.0.1",
    "sass-embedded": "^1.83.1",
    "semver": "7.7.2",
    "tailwindcss": "4.1.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "utf-8-validate": "^6.0.6",
    "vite": "^6.1.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.8",
    "zustand": "^5.0.0"
  },
  "engines": {
    "node": ">=20.x"
  }
